<section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 via-blue-900 to-gray-900 text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-20 w-72 h-72 bg-blue-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-20 w-96 h-96 bg-purple-500 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-6 text-center">
    <div class="inline-block bg-blue-600/20 border border-blue-500/30 rounded-full px-4 py-1.5 mb-6">
      <span class="text-blue-300 text-sm font-medium">基于 YOLO26 + SAM 2 + Supervision</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
      AI 视觉分析<br/>
      <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">让监控更智能</span>
    </h1>

    <p class="text-xl md:text-2xl text-gray-300 mb-10 max-w-3xl mx-auto leading-relaxed">
      端到端检测 + 精细分割 + 零样本识别<br/>
      多路并发，自适应降级，生产级架构
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#features" class="bg-blue-600 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-blue-700 transition-all hover:scale-105 shadow-lg shadow-blue-600/30">
        了解核心能力
      </a>
      <a href="#contact" class="bg-white/10 backdrop-blur border border-white/20 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-white/20 transition-all hover:scale-105">
        免费咨询
      </a>
    </div>

    <!-- Quick stats -->
    <div class="mt-16 grid grid-cols-3 gap-8 max-w-2xl mx-auto">
      <div>
        <div class="text-3xl md:text-4xl font-bold text-blue-400">25+</div>
        <div class="text-gray-400 mt-1">GPU FPS</div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold text-blue-400">6 路</div>
        <div class="text-gray-400 mt-1">最大并发</div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold text-blue-400">&lt;80ms</div>
        <div class="text-gray-400 mt-1">P95 延迟</div>
      </div>
    </div>
  </div>
</section>
