---
interface Props {
  title: string;
  description: string;
  metric: string;
}
---

<section class="bg-white rounded-2xl shadow-lg p-8 hover:shadow-xl transition-shadow duration-300 border-t-4 border-blue-600">
  <h3 class="text-xl font-bold text-gray-900 mb-2">{Astro.props.title}</h3>
  <p class="text-gray-600 mb-4 leading-relaxed">{Astro.props.description}</p>
  <span class="inline-block bg-blue-100 text-blue-800 text-sm font-semibold px-3 py-1 rounded-full">{Astro.props.metric}</span>
</section>
